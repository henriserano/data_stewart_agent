# Only needed if you want to run the MCP server locally (uvicorn) against a remote OpenMetadata.
# In AWS, secrets come from SSM SecureString parameters — no .env involved.
OPENMETADATA_HOST=https://sandbox.open-metadata.org
OPENMETADATA_JWT=eyJhbGciOi...
MCP_BEARER_TOKEN=change-me-to-a-random-string
